# Copy this to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars to source control.

project     = "devops-suite"
environment = "staging"
aws_region  = "us-east-1"

# Networking
vpc_cidr             = "10.0.0.0/16"
private_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
public_subnet_cidrs  = ["10.0.101.0/24", "10.0.102.0/24", "10.0.103.0/24"]

# Database
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_password          = "REPLACE_ME"

# Redis
redis_node_type = "cache.t3.micro"

# ECS
ecr_image_uri         = "123456789012.dkr.ecr.us-east-1.amazonaws.com/devops-suite"
task_cpu              = 512
task_memory           = 1024
service_desired_count = 2

# App
secret_key = "REPLACE_ME_WITH_RANDOM_STRING"
